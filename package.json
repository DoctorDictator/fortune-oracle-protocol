{
  "name": "chainlink-fortune-dapp",
  "license": "MIT",
  "version": "3.0.0",
  "description": "Advanced Fortune dApp using Chainlink VRF v2.5 on Sepolia",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test tests/FortuneProtocol.test.js",
    "deploy": "hardhat run scripts/deploy.js --network",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia && node scripts/export-abi.js",
    "verify": "hardhat verify --network",
    "export:abi": "node scripts/export-abi.js",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "coverage": "hardhat coverage --solcoverjs ./.solcover.js",
    "format": "prettier --write .",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "hardhat compile && node scripts/export-abi.js && cd frontend && npm run build"
  },
  "devDependencies": {
    "@chainlink/contracts": "^1.3.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.10",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.4.1",
    "dotenv": "^16.4.0",
    "ethers": "^6.0.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "prettier-plugin-solidity": "^1.3.0",
    "solhint": "^4.1.0",
    "solidity-coverage": "^0.8.7",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
